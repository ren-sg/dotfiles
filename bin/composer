#!/usr/bin/env bash
set -euo pipefail

find_env_file() {
  local dir="$PWD"
  while true; do
    if [[ -f "$dir/.env" ]]; then
      echo "$dir/.env"
      return 0
    fi
    [[ "$dir" == "/" ]] && return 1
    dir="$(dirname "$dir")"
  done
}

load_dotenv() {
  local env_file="$1"
  local line key val

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$line" || "${line:0:1}" == "#" ]] && continue
    [[ "$line" == export\ * ]] && line="${line#export }"
    [[ "$line" != *"="* ]] && continue

    key="${line%%=*}"
    val="${line#*=}"

    key="${key%"${key##*[![:space:]]}"}"
    key="${key#"${key%%[![:space:]]*}"}"
    [[ -z "$key" ]] && continue
    [[ ! "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] && continue

    val="${val#"${val%%[![:space:]]*}"}"
    if [[ ( "${val:0:1}" == "\"" && "${val: -1}" == "\"" ) || ( "${val:0:1}" == "'" && "${val: -1}" == "'" ) ]]; then
      val="${val:1:${#val}-2}"
    fi

    if [[ -z "${!key-}" ]]; then
      export "$key=$val"
    fi
  done < "$env_file"
}

if ENV_FILE="$(find_env_file)"; then
  load_dotenv "$ENV_FILE"
fi

PHP_IMAGE_VERSION="${PHP_IMAGE_VERSION:-8.3}"
IMAGE="local/php-cli:${PHP_IMAGE_VERSION}-dev"

CONF_DIR="$HOME/.local/php-docker/${PHP_IMAGE_VERSION}/conf.d"
[[ -d "$CONF_DIR" ]] || { echo "No conf dir: $CONF_DIR" >&2; exit 1; }

docker run --rm -it \
  --add-host=host.docker.internal:host-gateway \
  -u "$(id -u)":"$(id -g)" \
  -v "$PWD":/app -w /app \
  -v "$CONF_DIR":/usr/local/etc/php/conf.d \
  -e XDEBUG_MODE="${XDEBUG_MODE:-off}" \
  -e PHP_IMAGE_VERSION="${PHP_IMAGE_VERSION:-}" \
  -e PHP_IDE_CONFIG="${PHP_IDE_CONFIG:-}" \
  "$IMAGE" \
  composer "$@"
